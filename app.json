{
  "expo": {
    "name": "BlackCat",
    "slug": "BlackCat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "blackcat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "edgeToEdgeEnabled": true,
    "predictiveBackGestureEnabled": false,

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "package": "com.yoliana_adel.BlackCat",
      "googleServicesFile": "./google-services.json"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-font",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "eas": {
        "projectId": "fbab0de4-ffd7-4349-aa72-6ba18422af1e"
      }
    }
  }
}
